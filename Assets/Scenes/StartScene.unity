  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uC120\uACF5\uC774\uB77C\uBA74 [ \uD55C \uC7A5 / \uAC19\uC740 \uC22B\uC790
    \uC5EC\uB7EC \uC7A5 / \uAC19\uC740 \uBB38\uC591\uC758 \uC5F0\uC18D\uB41C \uC22B\uC790
    \uC138 \uC7A5 \uC774\uC0C1 ] \uC758 \uADDC\uCE59\uC73C\uB85C \uCE74\uB4DC\uB97C
    \uC81C\uCD9C\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.\n\uC120\uACF5\uC774 \uC544\uB2C8\uB77C\uBA74
    \uB77C\uC6B4\uB4DC\uAC00 \uB05D\uB0A0 \uB54C\uAE4C\uC9C0 \uC120\uACF5\uC774 \uC815\uD55C
    \uADDC\uCE59\uC73C\uB85C \uCE74\uB4DC\uB97C \uC81C\uCD9C\uD574\uC57C \uD569\uB2C8\uB2E4.\n\uC544\uB798
    \uC18C\uAC1C\uB41C \uB2E4\uC591\uD55C \uD2B9\uC218 \uADDC\uCE59\uC744 \uC801\uC808\uD788
    \uD65C\uC6A9\uD574\uC11C \uC190\uD328\uB97C \uBA3C\uC800 \uD138\uC5B4\uBCF4\uC138\uC694.\n\n\n\n\n\n\n\n\n\n\n\n\n\uACC4\uAE09\uC744
    \uB192\uAC8C \uC720\uC9C0\uD558\uC138\uC694.\n\n\uACC4\uAE09\uC774 \uC815\uD574\uC9C4
    \uD6C4\uBD80\uD130\uB294, \uAC01 \uAC8C\uC784 \uC2DC\uC791 \uC804 \uB192\uC740
    \uACC4\uAE09\uC758 \uD50C\uB808\uC774\uC5B4\uC640 \uB0AE\uC740 \uACC4\uAE09\uC758
    \uD50C\uB808\uC774\uC5B4\uAC00 \uCE74\uB4DC \uAD50\uD658\uC744 \uD569\uB2C8\uB2E4.\nDaifugo\uB294
    Daihinmin\uC758 \uAC00\uC7A5 \uC88B\uC740 \uB450 \uC7A5\uC744 \uAC15\uC81C\uB85C
    \uBE7C\uC557\uACE0, \uC790\uC2E0\uC758 \uCE74\uB4DC \uC911 \uC4F8\uBAA8 \uC5C6\uB294
    \uAC83\uC744 \uB450 \uC7A5 \uC90D\uB2C8\uB2E4.\nFugo\uB294 Hinmin\uACFC \uD55C
    \uC7A5\uC9DC\uB9AC \uAD50\uD658\uC744 \uC9C4\uD589\uD569\uB2C8\uB2E4.\nDaifugo\uAC00
    \uB418\uC5C8\uB2E4\uBA74 \uCD5C\uB300\uD55C \uACC4\uAE09\uC744 \uC624\uB798 \uC720\uC9C0\uD558\uC138\uC694.\n\uC548
    \uADF8\uB7EC\uBA74 \uC548 \uC88B\uC740 \uC77C\uC744 \uB2F9\uD560 \uC9C0\uB3C4
    \uBAA8\uB985\uB2C8\uB2E4..."
